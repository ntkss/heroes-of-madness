rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email == 'nattakit.suksaeng@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    // Players
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config Bootstrap
    match /config/bootstrap {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    !exists(/databases/$(database)/documents/config/bootstrap) && 
                    request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // Users
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role == 'user' || (
          request.resource.data.role == 'admin' && (
            request.auth.token.email == 'nattakit.suksaeng@gmail.com' ||
            existsAfter(/databases/$(database)/documents/config/bootstrap)
          )
        )
      );
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && request.resource.data.role == resource.data.role)
      );
      allow delete: if isAdmin();
    }
  }
}
